meta {
  name: POST Update restaurant Open
  type: http
  seq: 7
}

post {
  url: {{baseUrl}}/mcp
  body: json
  auth: inherit
}

headers {
  Content-Type: application/json
  Accept: application/json, text/event-stream
}

body:json {
  {
    "jsonrpc": "2.0",
    "method": "tools/call",
    "params": {
      "name": "update_restaurant_is_open",
      "arguments": {
        "is_open": true
      }
    },
    "id": 1
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
